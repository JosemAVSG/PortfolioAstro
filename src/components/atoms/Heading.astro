---
import type { HeadingProps } from '../../types';

interface Props extends HeadingProps {}

const { level = 1, class: className } = Astro.props;

const tag = `h${level}` as const;

const levelClasses: Record<number, string> = {
  1: 'text-2xl lg:text-4xl font-bold',
  2: 'text-xl lg:text-2xl font-semibold',
  3: 'text-lg font-semibold',
  4: 'text-base font-medium',
  5: 'text-sm font-medium',
  6: 'text-xs font-medium',
};
---

{tag === 'h1' && (
  <h1 class:list={['text-black dark:text-white', levelClasses[level], className]}>
    <slot />
  </h1>
)}

{tag === 'h2' && (
  <h2 class:list={['text-black dark:text-white', levelClasses[level], className]}>
    <slot />
  </h2>
)}

{tag === 'h3' && (
  <h3 class:list={['text-black dark:text-primary', levelClasses[level], className]}>
    <slot />
  </h3>
)}

{level >= 4 && (
  <p class:list={['text-black dark:text-white', levelClasses[level], className]}>
    <slot />
  </p>
)}