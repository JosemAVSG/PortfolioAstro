---
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang as 'es' | 'en');

const avatarUrl = 'https://avatars.githubusercontent.com/u/107879363?s=400&u=37610b02b2a4947fc2cf337710d5e6986a40f695&v=4';

const bio = [
  t('about.bio1'),
  t('about.bio2'),
  t('about.bio3'),
];

const skills = lang === 'es' 
  ? ['React', 'Next.js', 'TypeScript', 'Node.js', 'NestJS', 'AWS', 'PostgreSQL', 'MongoDB', 'Docker']
  : ['React', 'Next.js', 'TypeScript', 'Node.js', 'NestJS', 'AWS', 'PostgreSQL', 'MongoDB', 'Docker'];
---

<section class="space-y-8">
  <div class="flex flex-col md:flex-row gap-8 items-start">
    <div class="hero-img shrink-0">
      <div class="circulo"></div>
      <img width="200" height="200" src={avatarUrl} alt="Jose Miguel González"
        class="order-1 object-cover w-48 h-48 md:w-56 md:h-56 p-2 rounded-2xl bg-black/20 dark:bg-yellow-500/5 ring-2 ring-primary/20" />
    </div>
    <div class="flex-1 space-y-4">
      {bio.map((paragraph) => (
        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed" set:html={paragraph} />
      ))}
    </div>
  </div>

  <!-- Tech Stack -->
  <div class="pt-4">
    <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">
      {lang === 'es' ? 'Tech Stack' : 'Tech Stack'}
    </h4>
    <div class="flex flex-wrap gap-3">
      {skills.map((skill) => (
        <span class="px-3 py-1.5 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-sm rounded-full font-medium hover:bg-primary/10 hover:text-primary transition-colors">
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-img {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .circulo {
    position: absolute;
    width: 180px;
    height: 180px;
    border: 3px #f9f871;
    border-radius: 50%;
    animation: rotate-center 6s linear infinite;
  }
  @keyframes rotate-center {
    0% { transform: rotate(0); }
    100% { transform: rotate(360deg); }
  }
  @media (max-width: 768px) {
    .circulo { width: 140px; height: 140px; }
  }
</style>